# Anthropic Claude API key for AI generation calls. Leave empty locally until configured.
ANTHROPIC_API_KEY=

# Meshy API key for text-to-3D generation calls. Leave empty locally until configured.
MESHY_API_KEY=

# Server-side speech-to-text API key for voice transcription (0004 §5: STT runs
# server-side only; never shipped to the Unity client). Leave empty locally until configured.
OASIS_STT_API_KEY=

# Speech-to-text model identifier for the server-side adapter (0004 §5).
OASIS_STT_MODEL=

# GCP project identifier for Phase 1 cloud resources.
GCP_PROJECT=

# Alias used by some GCP tooling for the same project identifier.
GCP_PROJECT_ID=

# Primary GCP region for Phase 1 services.
GCP_REGION=

# Firebase project identifier for authentication.
FIREBASE_PROJECT_ID=

# Cloud Storage bucket for generated assets.
CLOUD_STORAGE_BUCKET=

# Phoenix database connection string placeholder for local integration work.
PHOENIX_DATABASE_URL=

# Runtime environment name: local | ci | staging | production.
OASIS_ENV=

# Dedicated (headless Unity) server port for local development. Reserved for
# Phase 2 multiplayer work — unused during the Phase 1 PoC.
UNITY_SERVER_PORT=
