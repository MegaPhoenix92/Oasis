# Anthropic Claude API key for AI generation calls. Leave empty locally until configured.
ANTHROPIC_API_KEY=

# Meshy API key for text-to-3D generation calls. Leave empty locally until configured.
MESHY_API_KEY=

# GCP project identifier for Phase 1 cloud resources.
GCP_PROJECT=

# Alias used by some GCP tooling for the same project identifier.
GCP_PROJECT_ID=

# Primary GCP region for Phase 1 services.
GCP_REGION=

# Firebase project identifier for authentication.
FIREBASE_PROJECT_ID=

# Cloud Storage bucket for generated assets.
CLOUD_STORAGE_BUCKET=

# Phoenix database connection string placeholder for local integration work.
PHOENIX_DATABASE_URL=

# Runtime environment name, such as local or ci.
OASIS_ENV=

# Dedicated server port for local development.
UNITY_SERVER_PORT=

